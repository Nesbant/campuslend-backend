# Backend server
PORT=4000
NODE_ENV=development

# Neon PostgreSQL / Sequelize
# Copia tu URL de conexión de Neon aquí en tu archivo .env local.
# No subas el archivo .env a tu repositorio.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# JWT
# Opcional en desarrollo, el backend tiene un valor por defecto.
# Establece un valor seguro en producción.
JWT_SECRET=change-this-local-secret
JWT_EXPIRES_IN_SECONDS=3600

# Sequelize
# Ponlo en 'true' solo si necesitas ver los logs de las queries SQL.
SEQUELIZE_LOGGING=false
