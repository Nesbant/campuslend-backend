# Backend server
PORT=4000
NODE_ENV=development

# Neon PostgreSQL / Sequelize
# Copy your Neon connection string here in your local .env.
# Do not commit .env.
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# JWT
# Optional in development because the backend has a fallback.
# Set a strong value in production/shared deployments.
JWT_SECRET=change-this-local-secret
JWT_EXPIRES_IN_SECONDS=3600

# Sequelize
# Set to true only when you need SQL query logs while debugging.
SEQUELIZE_LOGGING=false
